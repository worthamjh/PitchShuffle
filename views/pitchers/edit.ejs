<%- layout('layouts/boilerplate') %>

    <style>
        .view-toggle {
            margin-bottom: 1.5rem;
        }

        .zone-grid {
            display: grid;
            gap: 6px;
            margin: 0 auto;
        }

        .loc-box {
            width: 70px;
            height: 70px;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 0.6rem;
            font-weight: 700;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border: 2px solid transparent;
            transition: all 0.15s ease;
            user-select: none;
            padding: 4px;
            cursor: pointer;
        }

        @media (min-width: 576px) {
            .loc-box {
                width: 90px;
                height: 90px;
                font-size: 0.65rem;
            }
        }

        @media (min-width: 992px) {
            .loc-box {
                width: 110px;
                height: 110px;
                font-size: 0.75rem;
            }
        }

        .loc-box.strike {
            background-color: #d4edda;
            border-color: #2e7d4f;
            color: #155724;
        }

        .loc-box.chase {
            background-color: #fff3cd;
            border-color: #d4a017;
            color: #856404;
        }

        .loc-box.mid-mid {
            background-color: #fff3cd;
            border-color: #d4a017;
            color: #856404;
        }

        .loc-box.disabled {
            background-color: #e9ecef;
            border-color: #ced4da;
            color: #adb5bd;
            text-decoration: line-through;
        }

        .loc-box.empty {
            background: transparent;
            border-color: transparent;
            cursor: default;
            pointer-events: none;
        }

        .loc-box:not(.empty):hover {
            opacity: 0.85;
            transform: scale(1.05);
        }

        .zone-container {
            display: flex;
            justify-content: center;
            padding: 1rem 0;
        }

        .pitch-section {
            border: 1px solid #dee2e6;
            border-radius: 12px;
            padding: 1.25rem;
            margin-bottom: 1.5rem;
            background: #fff;
        }

        .pitch-section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }
    </style>

    <div class="page-header">
        <h1><i class="bi bi-pencil"></i> Edit <%= pitcher.name %>
        </h1>
    </div>

    <div class="card">
        <div class="card-body p-4">
            <form action="/teams/<%= team._id %>/pitchers/<%= pitcher._id %>?_method=PUT" method="POST"
                id="pitcherForm">

                <!-- Basic Info -->
                <h5 class="fw-bold mb-3">Basic Info</h5>
                <div class="row mb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label for="name" class="form-label fw-bold">Name</label>
                        <input type="text" class="form-control form-control-lg" id="name" name="pitcher[name]"
                            value="<%= pitcher.name %>" required>
                    </div>
                    <div class="col-md-3 mb-3 mb-md-0">
                        <label for="number" class="form-label fw-bold">Jersey #</label>
                        <input type="number" class="form-control form-control-lg" id="number" name="pitcher[number]"
                            value="<%= pitcher.number %>">
                    </div>
                    <div class="col-md-3">
                        <label for="throws" class="form-label fw-bold">Throws</label>
                        <select class="form-select form-select-lg" id="throws" name="pitcher[throws]">
                            <option value="R" <%=pitcher.throws==='R' ? 'selected' : '' %>>Right</option>
                            <option value="L" <%=pitcher.throws==='L' ? 'selected' : '' %>>Left</option>
                        </select>
                    </div>
                </div>

                <!-- Zone Selection -->
                <h5 class="fw-bold mb-3 mt-4">Strike Zone</h5>
                <div class="mb-4">
                    <div class="row row-cols-1 row-cols-md-2 g-3">
                        <% for (let zone of zones) { %>
                            <div class="col">
                                <input type="radio" class="btn-check" name="pitcher[zone]" id="zone-<%= zone._id %>"
                                    value="<%= zone._id %>" <%=pitcher.zone && pitcher.zone._id.equals(zone._id)
                                    ? 'checked' : '' %> required>
                                <label class="btn btn-outline-primary w-100 text-start p-3" for="zone-<%= zone._id %>">
                                    <strong>
                                        <%= zone.name %>
                                    </strong><br>
                                    <small class="text-muted">
                                        <%= zone.availableLocations.length %> locations
                                    </small>
                                </label>
                            </div>
                            <% } %>
                    </div>
                </div>

                <!-- Pitch Types Header + View Toggle -->
                <div class="d-flex justify-content-between align-items-center mb-3 mt-4">
                    <h5 class="fw-bold mb-0">Pitch Types & Locations</h5>
                    <div class="btn-group" role="group">
                        <input type="radio" class="btn-check" name="viewMode" id="visualMode" checked>
                        <label class="btn btn-outline-primary btn-sm" for="visualMode">
                            <i class="bi bi-grid-3x3"></i> Visual
                        </label>
                        <input type="radio" class="btn-check" name="viewMode" id="listMode">
                        <label class="btn btn-outline-primary btn-sm" for="listMode">
                            <i class="bi bi-list-check"></i> List
                        </label>
                    </div>
                </div>

                <!-- Pitch Type Sections -->
                <div id="pitchTypes">
                    <% for (var i=0; i < pitcher.pitchTypes.length; i++) { %>
                        <% var pitch=pitcher.pitchTypes[i]; %>
                            <div class="pitch-section pitch-type-row">
                                <div class="pitch-section-header">
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="text" class="form-control fw-bold"
                                            name="pitcher[pitchTypes][<%= i %>][name]" value="<%= pitch.name %>"
                                            placeholder="Pitch name" style="max-width:160px;">
                                        <input type="text" class="form-control"
                                            name="pitcher[pitchTypes][<%= i %>][abbreviation]"
                                            value="<%= pitch.abbreviation %>" placeholder="Abbr."
                                            style="max-width:80px;">
                                    </div>
                                    <button type="button" class="btn btn-outline-danger btn-sm remove-pitch">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>

                                <!-- VISUAL MODE -->
                                <div class="visual-view">
                                    <div class="zone-container">
                                        <div class="zone-grid" id="grid-<%= i %>">
                                            <!-- built by JS -->
                                        </div>
                                    </div>
                                </div>

                                <!-- LIST MODE -->
                                <div class="list-view" style="display:none;">
                                    <div class="d-flex flex-wrap gap-2 mt-2">
                                        <% for (var j=0; j < pitch.locations.length; j++) { %>
                                            <% var loc=pitch.locations[j]; %>
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input list-checkbox" type="checkbox"
                                                        id="list-loc-<%= i %>-<%= j %>" data-pitch="<%= i %>"
                                                        data-loc="<%= j %>" <%=loc.enabled ? 'checked' : '' %>>
                                                    <label
                                                        class="form-check-label badge p-2
                                            <%= loc.name === 'mid-mid' ? 'bg-warning text-dark' : loc.type === 'chase' ? 'bg-warning text-dark' : 'bg-success' %>"
                                                        for="list-loc-<%= i %>-<%= j %>">
                                                        <%= loc.name %>
                                                    </label>
                                                </div>
                                                <% } %>
                                    </div>
                                </div>

                                <!-- Hidden inputs for all locations -->
                                <div style="display:none;" id="hidden-<%= i %>">
                                    <% for (var j=0; j < pitch.locations.length; j++) { %>
                                        <% var loc=pitch.locations[j]; %>
                                            <input type="hidden"
                                                name="pitcher[pitchTypes][<%= i %>][locations][<%= j %>][name]"
                                                value="<%= loc.name %>">
                                            <input type="hidden"
                                                name="pitcher[pitchTypes][<%= i %>][locations][<%= j %>][type]"
                                                value="<%= loc.type %>">
                                            <input type="hidden" class="loc-enabled-input"
                                                id="enabled-<%= i %>-<%= j %>"
                                                name="pitcher[pitchTypes][<%= i %>][locations][<%= j %>][enabled]"
                                                value="<%= loc.enabled %>">
                                            <% } %>
                                </div>

                            </div>
                            <% } %>
                </div>

                <button type="button" class="btn btn-outline-secondary mb-4" id="addPitch">
                    <i class="bi bi-plus-circle"></i> Add Another Pitch
                </button>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle"></i> Save Changes
                    </button>
                    <a href="/teams/<%= team._id %>/pitchers/<%= pitcher._id %>"
                        class="btn btn-outline-secondary btn-lg">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>

            </form>
        </div>
    </div>

    <!-- Legend -->
    <div class="d-flex gap-3 mt-3 mb-4 flex-wrap">
        <span class="d-flex align-items-center gap-2">
            <span
                style="width:20px;height:20px;border-radius:4px;background:#d4edda;border:2px solid #2e7d4f;display:inline-block;"></span>
            <small>Strike location</small>
        </span>
        <span class="d-flex align-items-center gap-2">
            <span
                style="width:20px;height:20px;border-radius:4px;background:#fff3cd;border:2px solid #d4a017;display:inline-block;"></span>
            <small>Chase / mid-mid</small>
        </span>
        <span class="d-flex align-items-center gap-2">
            <span
                style="width:20px;height:20px;border-radius:4px;background:#e9ecef;border:2px solid #ced4da;display:inline-block;"></span>
            <small>Disabled</small>
        </span>
    </div>

    <script>
        const throws = '<%= pitcher.throws %>';
        const isRHP = throws === 'R';

        // Grid layout definitions
        // Each location maps to [row, col] in a grid
        // For RHP: arm=right, glove=left
        // For LHP: arm=left, glove=right
        // We define positions for RHP and flip cols for LHP

        const ZONE_LAYOUTS_A = {
            'arm-side':   { row: 1, col: isRHP ? 2 : 1 },
            'glove-side': { row: 1, col: isRHP ? 1 : 2 },
        };
        const ZONE_LAYOUTS_B = {
            'up':   { row: 1, col: 1 },
            'down': { row: 2, col: 1 },
        };
        const ZONE_LAYOUTS_C = {
            'up-out':          { row: 1, col: 2, colSpan: 3 },
            'glove-out':       { row: 2, col: isRHP ? 1 : 5, rowSpan: 2 },
            'glove-side-up':   { row: 2, col: isRHP ? 2 : 4 },
            'mid-mid':         { row: 2, col: 3, rowSpan: 2 },
            'arm-side-up':     { row: 2, col: isRHP ? 4 : 2 },
            'arm-out':         { row: 2, col: isRHP ? 5 : 1, rowSpan: 2 },
            'glove-side-down': { row: 3, col: isRHP ? 2 : 4 },
            'arm-side-down':   { row: 3, col: isRHP ? 4 : 2 },
            'down-out':        { row: 4, col: 2, colSpan: 3 },
        };
        const ZONE_LAYOUTS_D = {
            'glove-out-up':   { row: 1, col: isRHP ? 1 : 3 },
            'mid-out-up':     { row: 1, col: 2 },
            'arm-out-up':     { row: 1, col: isRHP ? 3 : 1 },
            'glove-up':       { row: 2, col: isRHP ? 1 : 3 },
            'mid-up':         { row: 2, col: 2 },
            'arm-up':         { row: 2, col: isRHP ? 3 : 1 },
            'glove-mid':      { row: 3, col: isRHP ? 1 : 3 },
            'mid-mid':        { row: 3, col: 2 },
            'arm-mid':        { row: 3, col: isRHP ? 3 : 1 },
            'glove-down':     { row: 4, col: isRHP ? 1 : 3 },
            'mid-down':       { row: 4, col: 2 },
            'arm-down':       { row: 4, col: isRHP ? 3 : 1 },
            'glove-out-down': { row: 5, col: isRHP ? 1 : 3 },
            'mid-out-down':   { row: 5, col: 2 },
            'arm-out-down':   { row: 5, col: isRHP ? 3 : 1 },
        };
        function getZoneLayouts(locations) {
            const names = new Set(locations.map(l => l.name));
            if (names.has('glove-up')) return ZONE_LAYOUTS_D;
            if (names.has('arm-side')) return ZONE_LAYOUTS_A;
            if (names.has('up')) return ZONE_LAYOUTS_B;
            return ZONE_LAYOUTS_C;
        }

        // Pitch data from server
        const pitchData = <%- JSON.stringify(pitcher.pitchTypes) %>;

        function getBoxClass(loc) {
            if (!loc.enabled) return 'disabled';
            if (loc.name === 'mid-mid') return 'mid-mid';
            if (loc.type === 'chase') return 'chase';
            return 'strike';
        }

        function buildGrid(pitchIndex) {
            const pitch = pitchData[pitchIndex];
            const grid = document.getElementById('grid-' + pitchIndex);
            if (!grid) return;

            const layouts = getZoneLayouts(pitch.locations);

            let maxRow = 1, maxCol = 1;
            pitch.locations.forEach(loc => {
                const pos = layouts[loc.name];
                if (pos) {
                    maxRow = Math.max(maxRow, pos.row + (pos.rowSpan || 1) - 1);
                    maxCol = Math.max(maxCol, pos.col + (pos.colSpan || 1) - 1);
                }
            });

            grid.style.gridTemplateColumns = `repeat(${maxCol}, auto)`;
            grid.style.gridTemplateRows = `repeat(${maxRow}, auto)`;

            pitch.locations.forEach((loc, j) => {
                const pos = layouts[loc.name];
                if (!pos) return;

                const box = document.createElement('div');
                box.classList.add('loc-box', getBoxClass(loc));
                box.textContent = loc.name.replace(/-/g, ' ');
                box.style.gridRow = pos.rowSpan ? `${pos.row} / span ${pos.rowSpan}` : String(pos.row);
                box.style.gridColumn = pos.colSpan ? `${pos.col} / span ${pos.colSpan}` : String(pos.col);
                box.dataset.pitch = pitchIndex;
                box.dataset.loc = j;
                box.dataset.enabled = loc.enabled;

                grid.appendChild(box);
            });
        }

        // Build all grids on load
        pitchData.forEach((pitch, i) => buildGrid(i));

        // --- View toggle ---
        document.getElementById('visualMode').addEventListener('change', () => {
            document.querySelectorAll('.visual-view').forEach(el => el.style.display = 'block');
            document.querySelectorAll('.list-view').forEach(el => el.style.display = 'none');
        });
        document.getElementById('listMode').addEventListener('change', () => {
            document.querySelectorAll('.visual-view').forEach(el => el.style.display = 'none');
            document.querySelectorAll('.list-view').forEach(el => el.style.display = 'block');
        });

        // --- Visual box toggle ---
        document.addEventListener('click', (e) => {
            const box = e.target.closest('.loc-box');
            if (!box || box.classList.contains('empty')) return;

            const pitch = box.dataset.pitch;
            const loc = box.dataset.loc;
            const enabled = box.dataset.enabled === 'true';
            const newEnabled = !enabled;

            box.dataset.enabled = newEnabled;

            // Get loc data from hidden inputs
            const nameInput = document.querySelector(`input[name="pitcher[pitchTypes][${pitch}][locations][${loc}][name]"]`);
            const typeInput = document.querySelector(`input[name="pitcher[pitchTypes][${pitch}][locations][${loc}][type]"]`);
            const name = nameInput ? nameInput.value : '';
            const type = typeInput ? typeInput.value : '';

            box.classList.remove('strike', 'chase', 'mid-mid', 'disabled');
            if (!newEnabled) {
                box.classList.add('disabled');
            } else if (name === 'mid-mid') {
                box.classList.add('mid-mid');
            } else if (type === 'chase') {
                box.classList.add('chase');
            } else {
                box.classList.add('strike');
            }

            // Sync hidden input
            const enabledInput = document.getElementById(`enabled-${pitch}-${loc}`);
            if (enabledInput) enabledInput.value = newEnabled;

            // Sync list checkbox
            const checkbox = document.getElementById(`list-loc-${pitch}-${loc}`);
            if (checkbox) checkbox.checked = newEnabled;
        });

        // --- List checkbox syncs to visual ---
        document.addEventListener('change', (e) => {
            const checkbox = e.target.closest('.list-checkbox');
            if (!checkbox) return;

            const pitch = checkbox.dataset.pitch;
            const loc = checkbox.dataset.loc;
            const newEnabled = checkbox.checked;

            const enabledInput = document.getElementById(`enabled-${pitch}-${loc}`);
            if (enabledInput) enabledInput.value = newEnabled;

            const box = document.querySelector(`.loc-box[data-pitch="${pitch}"][data-loc="${loc}"]`);
            if (box) {
                box.dataset.enabled = newEnabled;
                const nameInput = document.querySelector(`input[name="pitcher[pitchTypes][${pitch}][locations][${loc}][name]"]`);
                const typeInput = document.querySelector(`input[name="pitcher[pitchTypes][${pitch}][locations][${loc}][type]"]`);
                const name = nameInput ? nameInput.value : '';
                const type = typeInput ? typeInput.value : '';

                box.classList.remove('strike', 'chase', 'mid-mid', 'disabled');
                if (!newEnabled) {
                    box.classList.add('disabled');
                } else if (name === 'mid-mid') {
                    box.classList.add('mid-mid');
                } else if (type === 'chase') {
                    box.classList.add('chase');
                } else {
                    box.classList.add('strike');
                }
            }
        });

        // --- Add pitch ---
        let pitchCount = <%= pitcher.pitchTypes.length %>;
        document.getElementById('addPitch').addEventListener('click', () => {
            const container = document.getElementById('pitchTypes');
            const div = document.createElement('div');
            div.classList.add('pitch-section', 'pitch-type-row');
            div.innerHTML = `
        <div class="pitch-section-header">
            <div class="d-flex align-items-center gap-2">
                <input type="text" class="form-control fw-bold"
                    name="pitcher[pitchTypes][${pitchCount}][name]"
                    placeholder="Pitch name" style="max-width:160px;">
                <input type="text" class="form-control"
                    name="pitcher[pitchTypes][${pitchCount}][abbreviation]"
                    placeholder="Abbr." style="max-width:80px;">
            </div>
            <button type="button" class="btn btn-outline-danger btn-sm remove-pitch">
                <i class="bi bi-trash"></i>
            </button>
        </div>
        <p class="text-muted small">Save pitcher first to configure locations for new pitch types.</p>
    `;
            container.appendChild(div);
            pitchCount++;
        });

        // --- Remove pitch ---
        document.getElementById('pitchTypes').addEventListener('click', (e) => {
            if (e.target.closest('.remove-pitch')) {
                e.target.closest('.pitch-type-row').remove();
            }
        });
    </script>