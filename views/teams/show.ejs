<%- layout('layouts/boilerplate') %>

    <div class="page-header d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-shield-fill"></i>
            <%= team.name %>
        </h1>
        <a href="/teams/<%= team._id %>/pitchers/new" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Add Pitcher
        </a>
    </div>

    <% if (team.pitchers.length===0) { %>
        <div class="card">
            <div class="card-body text-center p-5">
                <i class="bi bi-person-fill display-1 text-muted"></i>
                <h4 class="mt-3 text-muted">No pitchers yet</h4>
                <p class="text-muted">Add your first pitcher to get started</p>
                <a href="/teams/<%= team._id %>/pitchers/new" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Add Pitcher
                </a>
            </div>
        </div>
        <% } else { %>
            <div class="row row-cols-1 row-cols-md-2 g-4">
                <% for (let pitcher of team.pitchers) { %>
                    <div class="col">
                        <div class="card h-100">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-person-fill"></i>
                                    <%= pitcher.name %>
                                </span>
                                <span class="badge bg-light text-dark">#<%= pitcher.number %></span>
                            </div>
                            <div class="card-body">
                                <p class="mb-1">
                                    <i class="bi bi-arrow-left-right"></i>
                                    Throws: <strong>
                                        <%= pitcher.throws==='R' ? 'Right' : 'Left' %>
                                    </strong>
                                </p>
                                <p class="mb-0 text-muted">
                                    <i class="bi bi-collection"></i>
                                    <%= pitcher.pitchTypes.length %> pitch type(s)
                                </p>
                            </div>
                            <div class="card-footer d-flex gap-2">
                                <a href="/teams/<%= team._id %>/pitchers/<%= pitcher._id %>" class="btn btn-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a href="/teams/<%= team._id %>/pitchers/<%= pitcher._id %>/edit"
                                    class="btn btn-outline-secondary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form action="/teams/<%= team._id %>/pitchers/<%= pitcher._id %>?_method=DELETE"
                                    method="POST" class="ms-auto">
                                    <button type="submit" class="btn btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <% } %>
            </div>
            <% } %>

                <div class="mt-3">
                    <a href="/teams" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Teams
                    </a>
                </div>