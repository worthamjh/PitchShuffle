<%- layout('layouts/boilerplate') %>

    <div class="page-header">
        <h1><i class="bi bi-plus-circle"></i> New Team</h1>
    </div>

    <div class="card">
        <div class="card-body p-4">
            <form action="/teams" method="POST">
                <div class="mb-4">
                    <label for="name" class="form-label fw-bold">Team Name</label>
                    <input type="text" class="form-control form-control-lg" id="name" name="team[name]" required>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle"></i> Create Team
                    </button>
                    <a href="/teams" class="btn btn-outline-secondary btn-lg">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>