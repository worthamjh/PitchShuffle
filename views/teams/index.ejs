<%- layout('layouts/boilerplate') %>

    <div class="page-header d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-people-fill"></i> My Teams</h1>
        <a href="/teams/new" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> New Team
        </a>
    </div>

    <% if (teams.length===0) { %>
        <div class="card">
            <div class="card-body text-center p-5">
                <i class="bi bi-people display-1 text-muted"></i>
                <h4 class="mt-3 text-muted">No teams yet</h4>
                <p class="text-muted">Get started by creating your first team</p>
                <a href="/teams/new" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Create a Team
                </a>
            </div>
        </div>
        <% } else { %>
            <div class="row row-cols-1 row-cols-md-2 g-4">
                <% for (let team of teams) { %>
                    <div class="col">
                        <div class="card h-100">
                            <div class="card-header">
                                <i class="bi bi-shield-fill"></i>
                                <%= team.name %>
                            </div>
                            <div class="card-body">
                                <p class="text-muted">
                                    <i class="bi bi-person-fill"></i>
                                    <%= team.pitchers.length %> pitcher(s)
                                </p>
                            </div>
                            <div class="card-footer d-flex gap-2">
                                <a href="/teams/<%= team._id %>" class="btn btn-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a href="/teams/<%= team._id %>/edit" class="btn btn-outline-secondary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form action="/teams/<%= team._id %>?_method=DELETE" method="POST" class="ms-auto">
                                    <button type="submit" class="btn btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <% } %>
            </div>
            <% } %>