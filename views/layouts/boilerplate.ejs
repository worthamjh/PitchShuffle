<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PitchShuffle</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --ps-navy: #1a2e4a;
            --ps-navy-dark: #111e30;
            --ps-green: #2e7d4f;
            --ps-green-light: #3a9e63;
            --ps-bg: #f0f0eb;
            --ps-card-bg: #ffffff;
            --ps-text: #1a1a1a;
            --ps-muted: #6c757d;
        }

        body {
            background-color: var(--ps-bg);
            color: var(--ps-text);
            font-family: 'Segoe UI', sans-serif;
        }

        /* Navbar */
        .navbar {
            background-color: var(--ps-navy) !important;
            padding: 0.75rem 1.5rem;
        }

        .navbar-brand {
            color: #ffffff !important;
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.85) !important;
            font-weight: 500;
            font-size: 1rem;
        }

        .nav-link:hover {
            color: #ffffff !important;
        }

        /* Cards */
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            background-color: var(--ps-card-bg);
        }

        .card-header {
            background-color: var(--ps-navy);
            color: #ffffff;
            border-radius: 12px 12px 0 0 !important;
            font-weight: 600;
            font-size: 1.1rem;
            padding: 1rem 1.25rem;
        }

        /* Buttons */
        .btn-primary {
            background-color: var(--ps-navy);
            border-color: var(--ps-navy);
            font-weight: 600;
            padding: 0.5rem 1.25rem;
        }

        .btn-primary:hover {
            background-color: var(--ps-navy-dark);
            border-color: var(--ps-navy-dark);
        }

        .btn-success {
            background-color: var(--ps-green);
            border-color: var(--ps-green);
            font-weight: 600;
            padding: 0.5rem 1.25rem;
        }

        .btn-success:hover {
            background-color: var(--ps-green-light);
            border-color: var(--ps-green-light);
        }

        /* Flash messages */
        .alert {
            border-radius: 10px;
            font-weight: 500;
        }

        /* Page header */
        .page-header {
            background-color: var(--ps-navy);
            color: #ffffff;
            padding: 1.25rem 1.5rem;
            border-radius: 12px;
            margin-bottom: 1.5rem;
        }

        .page-header h1 {
            font-size: 1.6rem;
            font-weight: 700;
            margin: 0;
        }

        /* Main content */
        main {
            padding: 1.5rem;
            max-width: 960px;
            margin: 0 auto;
        }
    </style>
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-md">
        <div class="container-fluid">
            <a class="navbar-brand" href="/teams">
                <i class="bi bi-bullseye"></i> PitchShuffle
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <% if (currentUser) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/teams">
                                <i class="bi bi-people-fill"></i> My Teams
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/logout">
                                <i class="bi bi-box-arrow-right"></i> Logout
                            </a>
                        </li>
                        <% } else { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/login">
                                    <i class="bi bi-box-arrow-in-right"></i> Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/register">
                                    <i class="bi bi-person-plus"></i> Register
                                </a>
                            </li>
                            <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Flash messages -->
    <div class="container mt-3">
        <% if (success && success.length) { %>
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle-fill"></i>
                <%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>
                <% if (error && error.length) { %>
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <%= error %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <% } %>
    </div>

    <!-- Main content -->
    <main>
        <%- body %>
    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>